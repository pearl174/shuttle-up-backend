// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  profile   Profile?
}

model Profile {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  user           User   @relation(fields: [userId], references: [id])
  profilePicPath String @default("")
  streak         Int    @default(0)
  quote          String @default("")

  friends  Profile[] @relation("ProfileFriends")
  friendOf Profile[] @relation("ProfileFriends")

  friendRequests   Profile[] @relation("FriendRequests") // many to many relation
  friendRequestsBy Profile[] @relation("FriendRequests")

  activityLogs ActivityLog[]
  player       Team[]
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  profileId Int
  profile   Profile  @relation(fields: [profileId], references: [id])
  date      DateTime
  count     Int
}

model Match {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  startTime DateTime
  endTime   DateTime
  winnerId  Int      @unique
  winner    Team     @relation("MatchWinner", fields: [winnerId], references: [id])
  teams     Team[]   @relation("MatchTeams")
}

model Team {
  id          Int       @id @default(autoincrement())
  player      Profile[]
  matchId     Int
  match       Match     @relation("MatchTeams", fields: [matchId], references: [id])
  matchWinner Match?    @relation("MatchWinner")
  score       Int
}
